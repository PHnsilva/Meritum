generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  PROFESSOR
  PARTNER
  INSTITUTION

  @@map("role")
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  cpf            String?         @unique
  passwordHash       String          @map("password_hash")
  role               Role
  mustChangePassword Boolean         @default(false) @map("must_change_password")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  student        Student?
  professor      Professor?
  partnerCompany PartnerCompany?
  institution    Institution?

  @@map("users")
}

model Institution {
  id         String            @id @default(uuid())
  userId     String?           @unique @map("user_id")
  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  name       String            @unique
  status     InstitutionStatus @default(APPROVED) @map("status")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  students   Student[]
  professors Professor[]

  @@map("institutions")
}

model Student {
  id                   String        @id @default(uuid())
  userId               String        @unique @map("user_id")
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rg                   String        @unique
  address              String
  course               String
  coinBalance          Int           @default(0) @map("coin_balance")
  institutionId        String        @map("institution_id")
  institution          Institution   @relation(fields: [institutionId], references: [id])
  receivedTransactions Transaction[]
  redemptions          Redemption[]
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  @@map("students")
}

model Professor {
  id            String        @id @default(uuid())
  userId        String        @unique @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  department    String
  coinBalance   Int           @default(1000) @map("coin_balance")
  institutionId String        @map("institution_id")
  institution   Institution   @relation(fields: [institutionId], references: [id])
  transactions  Transaction[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("professors")
}

enum PartnerStatus {
  PENDING
  APPROVED

  @@map("partner_status")
}

enum InstitutionStatus {
  PENDING
  APPROVED

  @@map("institution_status")
}

model PartnerCompany {
  id            String        @id @default(uuid())
  userId        String        @unique @map("user_id")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  corporateName String        @map("corporate_name")
  tradeName     String?       @map("trade_name")
  cnpj          String        @unique
  address       String
  status        PartnerStatus @default(APPROVED) @map("status")
  advantages    Advantage[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("partner_companies")
}

model Advantage {
  id          String         @id @default(uuid())
  title       String
  description String
  imageUrl    String?        @map("image_url")
  costInCoins Int            @map("cost_in_coins")
  isActive    Boolean        @default(true) @map("is_active")
  partnerId   String         @map("partner_id")
  partner     PartnerCompany @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  redemptions Redemption[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("advantages")
}

model Redemption {
  id          String    @id @default(uuid())
  code        String    @unique
  coinCost    Int       @map("coin_cost")
  studentId   String    @map("student_id")
  student     Student   @relation(fields: [studentId], references: [id])
  advantageId String    @map("advantage_id")
  advantage   Advantage @relation(fields: [advantageId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("redemptions")
}

model Transaction {
  id          String    @id @default(uuid())
  amount      Int
  motive      String
  professorId String    @map("professor_id")
  studentId   String    @map("student_id")
  professor   Professor @relation(fields: [professorId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("transactions")
}
