# ============================================================
# Backend Meritum — variáveis de ambiente
# Copie para .env (desenvolvimento) e preencha no painel do Render (produção).
# ============================================================

# --- Banco de dados (OBRIGATÓRIO) ---
# Local (docker-compose): postgresql://admin:admin@postgres:5432/meritum?schema=public
# Produção: use a connection string do provedor + sslmode=require quando for externo
DATABASE_URL="postgresql://admin:admin@localhost:5432/meritum?schema=public"

# --- Autenticação (OBRIGATÓRIO em produção) ---
# Gere com: openssl rand -hex 32
# Se NODE_ENV=production e JWT_SECRET faltar, a aplicação NÃO sobe (proposital).
JWT_SECRET="troque-por-um-segredo-forte"
NODE_ENV="development"

# --- Servidor (opcionais; defaults entre parênteses) ---
PORT="3333"          # (3333)
HOST="0.0.0.0"       # (0.0.0.0)

# --- URL do frontend (usada nos links dos e-mails) ---
# Em produção aponte para o domínio do Vercel, senão os links vão para localhost.
FRONTEND_URL="http://localhost:5173"

# --- CORS: origens permitidas (separadas por vírgula) ---
# Se vazio, o backend libera apenas localhost:5173 e localhost:4173 (dev).
# Em produção DEFINA a URL do Vercel, senão o frontend será bloqueado por CORS.
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"

# --- Admin inicial (criado pelo seed) ---
# Em produção DEFINA ADMIN_PASSWORD com uma senha forte; sem ela o seed NÃO cria o admin em prod.
# Em dev, se vazio, usa admin@meritum.com / admin123.
ADMIN_EMAIL="admin@meritum.com"
ADMIN_PASSWORD=""

# --- RabbitMQ (OPCIONAL) ---
# Se vazio, o sistema usa um event-bus em memória (eventos não duráveis/distribuídos).
# Em produção sempre-ligada use o amqps:// do CloudAMQP.
RABBITMQ_URL="amqp://meritum:meritum@localhost:5672"
RABBITMQ_EXCHANGE="meritum.domain-events"
RABBITMQ_QUEUE_PREFIX="meritum"

# --- E-mail transacional (OPCIONAL) ---
# O provedor é escolhido nesta ordem: 1) Resend  2) SMTP  3) Ethereal (teste).
#
# 1) RESEND (recomendado em produção): usa a API HTTP (porta 443), então funciona no Render,
#    que BLOQUEIA as portas SMTP 25/465/587 no plano free.
#    Crie a chave em https://resend.com/api-keys e verifique o domínio em https://resend.com/domains.
#    Sem RESEND_API_KEY o sistema cai para SMTP; sem SMTP, usa Ethereal (NÃO entrega e-mail real, só gera preview).
RESEND_API_KEY=""

# Remetente usado por qualquer provedor. Com Resend precisa ser de um domínio verificado
# (ex.: "Meritum <no-reply@meritum.com.br>") OU "Meritum <onboarding@resend.dev>" para testes
# (este domínio de teste só entrega para o e-mail da sua própria conta Resend).
MAIL_FROM="Meritum <no-reply@meritum.com.br>"

# 2) SMTP (nodemailer) — usado só se RESEND_API_KEY estiver vazio. Útil em dev local ou hosts
#    sem bloqueio de porta. NÃO funciona no plano free do Render.
SMTP_HOST=""
SMTP_USER=""
SMTP_PASS=""
SMTP_PORT="587"
# SMTP_FROM é fallback legado de MAIL_FROM (use MAIL_FROM de preferência).
SMTP_FROM="no-reply@meritum.com.br"
