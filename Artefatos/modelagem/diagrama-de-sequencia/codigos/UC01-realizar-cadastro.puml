@startuml
title UC01 - Realizar Cadastro

actor Aluno as A
boundary "Frontend\nReact/Vite" as FE
control "Sistema de\nGerenciamento" as SG
database "Banco de\nDados" as BD

A -> FE: 1.1 acessarTelaCadastro()
activate FE
FE --> A: 1.2 exibirFormularioCadastro()
deactivate FE

A -> FE: 1.3 preencherDados(nome, email, cpf, rg, endereco, instituicao, curso, senha)
activate FE
A -> FE: 1.4 confirmarCadastro()

FE -> SG: 1.5 cadastrarAluno(dadosAluno)
activate SG

SG -> SG: 1.6 validarCamposObrigatorios(dadosAluno)

alt Campo obrigatório não preenchido
    SG --> FE: 1.7 erroValidacao(camposInvalidos)
    FE --> A: 1.8 exibirCamposInvalidos(camposInvalidos)
else Dados mínimos válidos
    SG -> BD: 1.9 verificarAlunoExistente(cpf, email)
    activate BD
    BD --> SG: 1.10 resultadoVerificacao
    deactivate BD

    alt CPF ou email já cadastrado
        SG --> FE: 1.11 erroCadastroDuplicado(cpfOuEmail)
        FE --> A: 1.12 solicitarCorrecaoDados()
    else Cadastro permitido
        SG -> SG: 1.13 gerarHashSenha(senha)
        SG -> BD: 1.14 salvarAluno(dadosAluno, passwordHash)
        activate BD

        alt Falha ao persistir dados
            BD --> SG: 1.15 erroPersistencia()
            deactivate BD
            SG --> FE: 1.16 erroGenericoCadastro()
            FE --> A: 1.17 orientarNovaTentativa()
        else Persistência bem-sucedida
            BD --> SG: 1.18 alunoCriado(alunoID)
            deactivate BD
            SG --> FE: 1.19 cadastroRealizado(alunoID)
            FE --> A: 1.20 exibirMensagemSucesso()
        end
    end
end

deactivate SG
deactivate FE
@enduml
